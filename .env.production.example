# ============================================================
# 央企海外工程供应链平台 · 生产环境变量模板
#
# 用法:
#   cp .env.production.example .env.production
#   vim .env.production    # 填真实值
#   chmod 600 .env.production
#
# 重要:.env.production 严禁入库(.gitignore 已排除)
# ============================================================

# ----- 发布版本 -----
# 必须与打包时 --tag 一致,例如 20260624-01
RELEASE_TAG=CHANGEME_release_tag

# ----- 数据库(compose 内置 PG 容器,与外部 PG 无关)-----
POSTGRES_DB=overseas_supply
POSTGRES_USER=overseas_app
# 强密码,用 openssl rand -base64 24 生成
POSTGRES_PASSWORD=CHANGEME_strong_random_password

# ----- JWT -----
# 用 openssl rand -hex 32 生成,严禁用示例值
JWT_SECRET_KEY=CHANGEME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- 初始 super admin(首次部署后立即改密)-----
SUPER_ADMIN_EMAIL=superadmin@platform.local
SUPER_ADMIN_INITIAL_PASSWORD=CHANGEME_set_strong_initial_password

# ----- demo 账号(真生产必须 false)-----
SEED_DEMO_ACCOUNTS=false

# ----- 公网访问入口 -----
# 浏览器访问后端的 URL（运行时注入，改完重启容器即可，不用重新 build）
# 推荐宿主机 Nginx 单域名入口: / -> frontend, /api/ 与 /static/ -> backend。
API_BASE_URL=https://YOUR_DOMAIN

# 后端 CORS 允许的来源(逗号分隔)
# 必须包含前端访问入口(浏览器的 origin)
CORS_ORIGINS=https://YOUR_DOMAIN
CORS_ALLOW_CREDENTIALS=true

# ----- Refresh token cookie -----
# HTTPS 生产入口必须 SECURE=true;本地纯 HTTP 临时验证才改 false。
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_MAX_AGE=604800
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax

# ----- 登录限流 -----
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_LOCK_SECONDS=300

# ----- 图片 -----
# 商品图片访问基础 URL（替换成实际公网地址）
IMAGE_BASE_URL=https://YOUR_DOMAIN/static
# 首页轮播图目录（离线包默认自带 data/banners,OpenResty 可直接指向同一目录）
BANNER_DIR=./data/banners

# ----- 本机容器端口 -----
# 宿主机 Nginx 反代时只绑定 127.0.0.1,不要直接暴露公网。
BACKEND_BIND_HOST=127.0.0.1
BACKEND_HOST_PORT=8001
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_HOST_PORT=3001

# ----- 翻译服务(i18n) -----
# 可选值: google / aliyun / mock / none
# 缺凭据时自动降级为 none（不翻译）
# 离线/无网环境用 mock
TRANSLATION_PROVIDER=google

# Google Translate（TRANSLATION_PROVIDER=google 时必填）
GOOGLE_TRANSLATE_API_KEY=
# GOOGLE_TRANSLATE_TIMEOUT_SECONDS=10

# 阿里云翻译（TRANSLATION_PROVIDER=aliyun 时必填）
# ALIYUN_TRANSLATE_ACCESS_KEY_ID=
# ALIYUN_TRANSLATE_ACCESS_KEY_SECRET=
# ALIYUN_TRANSLATE_REGION=cn-hangzhou

# 通义千问 API Key（AI 摘要等功能用，非必填）
# DASHSCOPE_API_KEY=

# i18n 翻译扫描配置（一般不需要改）
# I18N_SWEEP_INTERVAL_SECONDS=300
# I18N_SWEEP_BATCH_LIMIT=5000

# ----- SMTP 邮件（密码找回验证码）-----
# 未配置时静默跳过发送，验证码打印到后端日志
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@buildlink.co.tz
SMTP_USE_TLS=true

# ----- 日志 -----
LOG_LEVEL=INFO

# ----- Trace ID 信任开关 -----
# 上反向代理且由网关注入并覆盖 X-Trace-Id 后再置 true;公网直连保持 false
TRUST_INBOUND_TRACE_ID=false

# ----- 地推演示白名单 -----
# 逗号分隔的 BUYER 邮箱，这些账号可看到 mock 订单追踪数据
NEXT_PUBLIC_DEMO_EMAILS=

# ----- 调试 API(生产建议 false)-----
ENABLE_DEBUG_API=false
