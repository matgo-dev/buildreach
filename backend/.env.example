# 数据库(PostgreSQL · brew postgresql@16 本机端口 5433)
DATABASE_URL=postgresql+asyncpg://liujingjing@localhost:5433/overseas_supply_dev

# JWT(必须用 openssl rand -hex 32 生成,严禁使用示例值)
JWT_SECRET_KEY=change-me-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# 初始超级管理员(种子,始终种入,生产唯一保留项)
SUPER_ADMIN_EMAIL=superadmin@platform.local
SUPER_ADMIN_INITIAL_PASSWORD=Aa123456789

# demo seed 总开关(控制中建三局 BuyerOrg + admin / operator / buyer demo 账号)
# 本地开发:true · 生产部署:**务必 false**,避免 demo 账号入网
SEED_DEMO_ACCOUNTS=true

# 日志
LOG_LEVEL=INFO

# CORS(逗号分隔，必须包含前端端口)
CORS_ORIGINS=http://localhost:7857

# Refresh token cookie(开发 http 用 False,生产 https 必须 True)
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_MAX_AGE=604800
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=strict
CORS_ALLOW_CREDENTIALS=true

# Trace ID 信任开关:上反向代理且由网关注入并覆盖 X-Trace-Id 后再置 true
TRUST_INBOUND_TRACE_ID=false
TRUST_PROXY=false

# Tavily 搜索 API(Δ7 柬埔寨公开数据源抓取)
# 真实 key 绝不进 Git;此处仅占位,实际值写本地 .env / ECS .env.production
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com
TAVILY_TIMEOUT_SECONDS=15
TAVILY_MAX_RESULTS_PER_QUERY=5

# 客服联系方式
WHATSAPP_DEFAULT_NUMBER="+255 758 311 131"
CONTACT_EMAIL=info@buildreach.co.tz
WECHAT_ID=
WECHAT_QR_IMAGE=

# SMTP 邮件（验证码）。本地可开启 EMAIL_DEV_LOG_CODES;生产必须关闭。
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@matgo.co.tz
SMTP_USE_TLS=true
EMAIL_DEV_LOG_CODES=true

# 买方注册是否强制邮箱验证码。默认 true(安全默认)。
# 邮件中继(SMTP)未就绪时,设为 false 让注册先上线;配好 SMTP 后删除本行即可恢复。
# 仅作用于买方注册,不影响密码找回。
# 注意:true 且 SMTP 未配置且 EMAIL_DEV_LOG_CODES=false 时,应用会 fail-fast 拒绝启动。
REQUIRE_EMAIL_VERIFICATION=true

# 抓取缓存与限速(Δ7)
CREDIT_HARVEST_CACHE_TTL_HOURS=24
CREDIT_HARVEST_TAVILY_CALLS_PER_HARVEST=10
CREDIT_HARVEST_LLM_TIMEOUT_SECONDS=30
CREDIT_HARVEST_LLM_RETRY=1
